# Telegram бот — токен от @BotFather
TELEGRAM_BOT_TOKEN=

# ID владельца бота (твой Telegram user id, чтобы бот отвечал только тебе)
# Узнать: напиши @userinfobot в Telegram
OWNER_TELEGRAM_ID=

# Модель Claude (необязательно). Если пусто — SDK берёт дефолт.
# Варианты: claude-sonnet-4-6, claude-opus-4-7, claude-haiku-4-5
CLAUDE_MODEL=

# Опционально — Deepgram для голосовых
DEEPGRAM_API_KEY=
