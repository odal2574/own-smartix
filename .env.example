# Telegram бот — токен от @BotFather
TELEGRAM_BOT_TOKEN=

# Anthropic API — ключ с console.anthropic.com
ANTHROPIC_API_KEY=

# Модель Claude. Рекомендую sonnet — оптимум цена/качество.
# Варианты: claude-sonnet-4-6, claude-opus-4-7, claude-haiku-4-5-20251001
CLAUDE_MODEL=claude-sonnet-4-6

# ID владельца бота (твой Telegram user id, чтобы бот отвечал только тебе)
# Узнать: напиши @userinfobot в Telegram
OWNER_TELEGRAM_ID=

# Опционально — Deepgram для голосовых
DEEPGRAM_API_KEY=
